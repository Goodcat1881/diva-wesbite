              "value": "Style Guide"
            },
            {
              "title": "Behind the Scenes",
              "value": "Behind the Scenes"
            }
          ]
        },
        "validation": [
          {
            "level": "error",
            "rules": [
              {
                "flag": "valid",
                "constraint": [
                  "Hair Tips",
                  "Colour",
                  "Treatments",
                  "Style Guide",
                  "Behind the Scenes"
                ]
              },
              {
                "flag": "presence",
                "constraint": "required"
              }
            ]
          }
        ],
        "name": "category",
        "type": "string"
