              {
                "flag": "max",
                "constraint": 200
              }
            ]
          }
        ],
        "name": "excerpt",
        "type": "text"
      },
      {
        "options": {
          "hotspot": true
        },
        "name": "image",
        "type": "image",
        "title": "Cover Image"
      },
      {
        "name": "readTime",
        "type": "string",
        "title": "Read Time (e.g. \"4 min read\")"
